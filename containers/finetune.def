Bootstrap: docker
# GPU torch baked in (web-verified tag, Docker Hub, mid-2026). CUDA 12.6 covers
# L4 (sm_89) / A100 (sm_80) / H100·H200 (sm_90). torch is NOT reinstalled from
# requirements.txt so this CUDA build is preserved. Ships Python 3.11.
From: pytorch/pytorch:2.8.0-cuda12.6-cudnn9-runtime

%files
  requirements.txt /opt/project/requirements.txt

%post
  # No apt step: this build runs without fakeroot (cluster has no subuid map),
  # so apt can't drop privileges and would error harmlessly. We don't need any
  # system package — git clones happen on the host, and all deps are pure-Python
  # wheels. If a future dep needs a compiler, add build-essential via a
  # fakeroot-enabled build instead.
  export PYTHONUNBUFFERED=1
  pip install --no-cache-dir -r /opt/project/requirements.txt

%environment
  export LC_ALL=C.UTF-8
  export LANG=C.UTF-8
  export PYTHONUNBUFFERED=1

%runscript
  exec python "$@"
